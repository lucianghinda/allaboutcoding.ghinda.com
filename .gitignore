# Secrets — never commit
bin/.hashnode_token
.env

# Drafts (_drafts/) ARE committed: Jekyll doesn't render them without --drafts,
# so they stay off the website but are versioned in this (public) repo.

# Hashnode tooling draft dump — kept local, not committed.
bin/data/hashnode_drafts.json

# Jekyll build output & caches
_site/
.jekyll-cache/
.jekyll-metadata
.sass-cache/

# Bundler
.bundle/
vendor/bundle/

# OS / editor
.DS_Store
*.swp
